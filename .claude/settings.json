{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm install *)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(bash .claude/hooks/*)",
      "Bash(npm run start*)",
      "Bash(npm start*)",
      "Bash(node --test*)",
      "Bash(node scripts/seo-audit.mjs*)",
      "Bash(git worktree add *)",
      "Bash(git worktree remove *)",
      "Bash(git worktree list*)",
      "Bash(git worktree prune*)",
      "Bash(curl http://localhost:3000*)",
      "Bash(curl -s http://localhost:3000*)",
      "Bash(curl -I http://localhost:3000*)",
      "Bash(curl -sI http://localhost:3000*)",
      "Bash(lsof -i:3000*)",
      "Bash(lsof -ti:3000*)",
      "Bash(pkill -f \"next dev\"*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "git commit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*__(merge_branch|execute_sql|apply_migration)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prod-write-guard.sh"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true
}