# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://explorebarbizon.com

# Command Center (admin dashboard)
COMMAND_CENTER_PASSWORD=

# Cloudflare R2 (media uploads — scripts/upload-media.mjs, scripts/upload-to-r2.mjs)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
NEXT_PUBLIC_MEDIA_BASE_URL=

# Supabase service-role key — required for admin writes (anon-key writes are
# RLS no-ops). SUPABASE_SERVICE_ROLE_KEY is also accepted (lib/supabaseAdmin.ts,
# scripts/upload-media.mjs both tolerate either name).
SUPABASE_SECRET_KEY=
